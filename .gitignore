# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
.build/
.buildlog/

# Flutter build artifacts
/build/

# Dart/Flutter generated files
*.jks
*.keystore

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug/
/android/app/profile/
/android/app/release/

# Local properties (contains SDK paths, don't commit)
android/local.properties

# Gradle wrapper (keep) but ignore Gradle caches
.android/
.gradle/

# Keystore/config not to commit
android/app/release/*.jks
android/app/release/*.keystore

# Generated Hive adapters (uncomment if you truly commit them)
# lib/**/*.g.dart

.venv/

